{
    "name": "rkdhatterwal/decodo-scraper",
    "description": "A Laravel package for the Decodo Web Scraping API — real-time, async, webhooks, DB tracking, caching, and testing helpers",
    "keywords": ["laravel", "decodo", "scraper", "web-scraping", "api", "webhook"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Rkdhatterwal\\DecodoScraper\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rkdhatterwal\\DecodoScraper\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rkdhatterwal\\DecodoScraper\\DecodoServiceProvider"
            ],
            "aliases": {
                "Decodo": "Rkdhatterwal\\DecodoScraper\\Facades\\Decodo",
                "DecodoAsync": "Rkdhatterwal\\DecodoScraper\\Facades\\DecodoAsync"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "lint": "vendor/bin/pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
